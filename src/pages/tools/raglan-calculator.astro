---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="魔法插肩毛衣计算器" description="从领口往下织的定制尺寸插肩毛衣计算工具">
  <div class="raglan-calc">
    <header class="rc-header">
      <h1>🧶 魔法插肩毛衣计算器</h1>
      <p>从领口往下织的定制尺寸插肩毛衣计算工具</p>
    </header>

    <div class="rc-container">
      <div class="rc-card no-print">
        <h2 data-icon="📖">简介</h2>
        <p>这款插肩毛衣从领口往下织，使用环形针一片式完成，可以适合从婴儿到成人的任何尺寸。可以改成开衫、圆领、堆领、V领或任何你想要的款式。</p>
        <div class="rc-tip">
          <strong>提示：</strong>这个计算器会帮你计算所需的所有针数。你只需要提供测量数据和密度！
        </div>
      </div>

      <div class="rc-tabs no-print">
        <button class="rc-tab active" data-tab="calculator">计算器</button>
        <button class="rc-tab" data-tab="reference">尺寸参考</button>
        <button class="rc-tab" data-tab="variations">款式变化</button>
      </div>

      <div id="calculator" class="rc-tab-content active">
        <div class="rc-card">
          <h2 data-icon="📏">第一步：测量密度</h2>
          <p>起26针，先织4行下针（搓板针），然后每行前3针和后3针织下针，中间20针织你想要的花样。织到中间部分至少10厘米高，再织4行下针后收针。水洗定型后测量。</p>
          <div class="rc-form-grid">
            <div class="rc-form-group">
              <label for="swatchWidth">样片宽度（20针）</label>
              <small>测量中间20针部分的宽度（厘米）</small>
              <input type="number" id="swatchWidth" step="0.1" min="1" placeholder="例如：10">
            </div>
            <div class="rc-form-group">
              <label>你的密度</label>
              <small>每厘米针数</small>
              <div class="rc-result-item" style="margin-top: 5px;">
                <span class="value" id="gaugeResult">--</span>
                <span class="unit">针/厘米</span>
              </div>
            </div>
          </div>
        </div>

        <div class="rc-card">
          <h2 data-icon="📐">第二步：输入测量数据</h2>
          <p>从穿着者身上量取这些数据，或使用参考表格（点击表格行可自动填入）。</p>
          <div class="rc-form-grid">
            <div class="rc-form-group">
              <label for="neckCirc">领围</label>
              <small>或想要的领口尺寸（厘米）</small>
              <input type="number" id="neckCirc" step="0.5" min="1" placeholder="例如：36">
            </div>
            <div class="rc-form-group">
              <label for="raglanLength">插肩长度</label>
              <small>锁骨到腋下（厘米）</small>
              <input type="number" id="raglanLength" step="0.5" min="1" placeholder="例如：30">
            </div>
            <div class="rc-form-group">
              <label for="bodyLength">身长</label>
              <small>腋下到下摆（厘米）</small>
              <input type="number" id="bodyLength" step="0.5" min="1" placeholder="例如：38">
            </div>
            <div class="rc-form-group">
              <label for="cuffCirc">袖口周长</label>
              <small>手腕尺寸（厘米）</small>
              <input type="number" id="cuffCirc" step="0.5" min="1" placeholder="例如：19">
            </div>
            <div class="rc-form-group">
              <label for="sleeveLength">袖长</label>
              <small>腋下到手腕（厘米）</small>
              <input type="number" id="sleeveLength" step="0.5" min="1" placeholder="例如：46">
            </div>
          </div>
        </div>

        <div class="rc-card">
          <h2 data-icon="🧮">第三步：针数计算结果</h2>
          <div class="rc-result-box">
            <h3>领口针数</h3>
            <div class="rc-result-grid">
              <div class="rc-result-item"><div class="label">领口总针数</div><div class="value" id="totalNeck">--</div><div class="unit">针</div></div>
              <div class="rc-result-item"><div class="label">后片</div><div class="value" id="backStitches">--</div><div class="unit">针</div></div>
              <div class="rc-result-item"><div class="label">每个袖子</div><div class="value" id="sleeveStitches">--</div><div class="unit">针</div></div>
              <div class="rc-result-item"><div class="label">前片</div><div class="value" id="frontStitches">--</div><div class="unit">针</div></div>
            </div>
          </div>
          <div class="rc-result-box" style="margin-top: 20px;">
            <h3>前片分解</h3>
            <div class="rc-result-grid">
              <div class="rc-result-item"><div class="label">左前</div><div class="value" id="leftFront">--</div><div class="unit">针</div></div>
              <div class="rc-result-item"><div class="label">前中心</div><div class="value" id="centerFront">--</div><div class="unit">针</div></div>
              <div class="rc-result-item"><div class="label">右前</div><div class="value" id="rightFront">--</div><div class="unit">针</div></div>
            </div>
          </div>
          <div class="rc-result-box" style="margin-top: 20px;">
            <h3>其他计算</h3>
            <div class="rc-result-grid">
              <div class="rc-result-item"><div class="label">袖口针数</div><div class="value" id="cuffStitches">--</div><div class="unit">针</div></div>
              <div class="rc-result-item"><div class="label">腋下加针</div><div class="value" id="underarmStitches">--</div><div class="unit">针（2.5cm）</div></div>
            </div>
          </div>
        </div>

        <div class="rc-card">
          <h2 data-icon="🎯">第四步：起针顺序</h2>
          <p>按以下顺序起针以形成领口造型：</p>
          <div class="rc-cast-on-diagram">
            <div class="rc-cast-on-order">
              <span class="rc-cast-on-item stitches">1针</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item marker-a">记号A</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item stitches">1针(加)</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item marker-b">记号B</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item stitches" id="sleeve1CastOn">袖+2</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item marker-b">记号B</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item stitches" id="backCastOn">后片+2</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item marker-b">记号B</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item stitches" id="sleeve2CastOn">袖+2</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item marker-b">记号B</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item stitches">1针(加)</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item marker-a">记号A</span>
              <span class="rc-arrow">→</span>
              <span class="rc-cast-on-item stitches">1针</span>
            </div>
            <p style="text-align: center; margin-top: 15px;">
              <strong>初始起针总数：<span id="initialCastOn">--</span> 针</strong>
            </p>
          </div>
          <div class="rc-warning">
            <strong>注意：</strong>4个B记号分隔前片、袖子和后片。2个A记号追踪前片加针。来回织，在正面行每个B记号前后加针，同时在每个正面行的开头和结尾加针，直到所有前片针数加完。
          </div>
        </div>

        <div class="rc-instructions-inline">
          <div class="rc-card">
            <h2 data-icon="✂️">所需工具</h2>
            <div class="rc-instructions-box">
              <ul>
                <li>所需用量的毛线（参考表格）</li>
                <li>环形针：40厘米和48厘米长度各一副</li>
                <li>2个同色记号扣（记号A）</li>
                <li>4个另一色记号扣（记号B）</li>
                <li>软尺</li>
                <li>别线或针数固定器</li>
              </ul>
            </div>
          </div>

          <div class="rc-card">
            <h2 data-icon="🔄">织领口</h2>
            <div class="rc-instructions-box">
              <p>领口起针是不完整的圆圈。来回织，在正面行每个B记号前后加针，同时在正面行开头和结尾加针，直到一半的前片针数加完。</p>
              <ol style="margin-top: 10px;">
                <li>按计算器显示的顺序起针</li>
                <li>来回织，在正面行每个B记号前后各加1针</li>
                <li>同时，在每个正面行的开头和结尾各加1针</li>
                <li>继续直到左前和右前的针数都加完</li>
                <li>一次性加上前中心的针数</li>
                <li>圈织</li>
              </ol>
            </div>
          </div>

          <div class="rc-card">
            <h2 data-icon="👕">织身体</h2>
            <div class="rc-instructions-box">
              <ol>
                <li>圈织后第一圈取下A记号</li>
                <li>继续织，每隔一圈在每个B记号前后加针</li>
                <li>当插肩长度达到测量值时，把袖子针数穿到别线上</li>
                <li>取下B记号</li>
                <li>在每个腋下加2.5厘米的针数</li>
                <li>继续圈织直筒到想要的身长</li>
                <li>收针前加罗纹或平面花样防止卷边</li>
              </ol>
            </div>
            <div class="rc-tip">
              <strong>身体造型选项：</strong>可以收腰、保持直筒、A字型、或沙漏型，在"侧缝"位置加减针即可。
            </div>
          </div>

          <div class="rc-card">
            <h2 data-icon="💪">织袖子</h2>
            <div class="rc-instructions-box">
              <ol>
                <li>把袖子针数穿到40厘米环形针上</li>
                <li>挑起腋下加的针数，圈织</li>
                <li>收袖：每2.5厘米在圈开头和结尾各减1针</li>
                <li>继续直到达到想要的袖口针数</li>
                <li>收针前加罗纹或平面花样</li>
                <li>罗纹用小一号针</li>
              </ol>
            </div>
            <div class="rc-warning">
              <strong>重要：</strong>记录第一只袖子的过程，第二只袖子照做！
            </div>
          </div>

          <div class="rc-card">
            <h2 data-icon="🎀">织领子</h2>
            <div class="rc-instructions-box">
              <p>沿领口（起针边）挑起所有针数织领子。选项包括：</p>
              <ul style="margin-top: 10px;">
                <li>2x2罗纹</li>
                <li>单罗纹</li>
                <li>与下摆和袖口花样统一</li>
                <li>装饰性边缘处理</li>
              </ul>
            </div>
          </div>
        </div>

        <div style="text-align: center;" class="no-print">
          <button class="rc-print-btn" onclick="window.print()">🖨️ 打印完整图样</button>
        </div>
      </div>

      <div id="reference" class="rc-tab-content">
        <div class="rc-card">
          <h2 data-icon="📊">标准尺寸参考表</h2>
          <p>如果无法直接测量穿着者，可使用这些数据。实际测量会得到更好的定制效果。</p>
          <div class="rc-click-hint">👆 点击表格中的任意行，自动填入测量数据</div>
          <div style="overflow-x: auto;">
            <table class="rc-yarn-table" id="sizeTable">
              <thead>
                <tr>
                  <th>尺码</th><th>胸围<br>(cm)</th><th>领围<br>(cm)</th><th>插肩<br>(cm)</th><th>袖长<br>(cm)</th><th>袖口<br>(cm)</th><th>身长<br>(cm)</th><th>粗线<br>(米)</th><th>中粗<br>(米)</th><th>细线<br>(米)</th>
                </tr>
              </thead>
              <tbody>
                <tr data-neck="23" data-raglan="18" data-sleeve="20" data-cuff="13" data-body="15"><td>童2</td><td>53</td><td>23</td><td>18</td><td>20</td><td>13</td><td>15</td><td>293</td><td>338</td><td>411</td></tr>
                <tr data-neck="24" data-raglan="20" data-sleeve="23" data-cuff="14" data-body="18"><td>童4</td><td>58</td><td>24</td><td>20</td><td>23</td><td>14</td><td>18</td><td>384</td><td>457</td><td>549</td></tr>
                <tr data-neck="25" data-raglan="22" data-sleeve="25" data-cuff="14" data-body="20"><td>童6</td><td>65</td><td>25</td><td>22</td><td>25</td><td>14</td><td>20</td><td>466</td><td>567</td><td>686</td></tr>
                <tr data-neck="28" data-raglan="23" data-sleeve="29" data-cuff="15" data-body="24"><td>童8</td><td>69</td><td>28</td><td>23</td><td>29</td><td>15</td><td>24</td><td>567</td><td>686</td><td>823</td></tr>
                <tr data-neck="30" data-raglan="25" data-sleeve="33" data-cuff="15" data-body="28"><td>童10</td><td>71</td><td>30</td><td>25</td><td>33</td><td>15</td><td>28</td><td>604</td><td>732</td><td>878</td></tr>
                <tr data-neck="33" data-raglan="27" data-sleeve="37" data-cuff="18" data-body="33"><td>童12</td><td>76</td><td>33</td><td>27</td><td>37</td><td>18</td><td>33</td><td>722</td><td>869</td><td>1042</td></tr>
                <tr data-neck="34" data-raglan="28" data-sleeve="41" data-cuff="18" data-body="34"><td>32</td><td>81</td><td>34</td><td>28</td><td>41</td><td>18</td><td>34</td><td>759</td><td>914</td><td>1097</td></tr>
                <tr data-neck="36" data-raglan="29" data-sleeve="42" data-cuff="18" data-body="36"><td>34</td><td>86</td><td>36</td><td>29</td><td>42</td><td>18</td><td>36</td><td>832</td><td>1006</td><td>1207</td></tr>
                <tr data-neck="37" data-raglan="30" data-sleeve="43" data-cuff="19" data-body="37"><td>36</td><td>91</td><td>37</td><td>30</td><td>43</td><td>19</td><td>37</td><td>951</td><td>1143</td><td>1372</td></tr>
                <tr data-neck="38" data-raglan="33" data-sleeve="44" data-cuff="19" data-body="38"><td>38</td><td>97</td><td>38</td><td>33</td><td>44</td><td>19</td><td>38</td><td>988</td><td>1189</td><td>1426</td></tr>
                <tr data-neck="39" data-raglan="36" data-sleeve="46" data-cuff="20" data-body="39"><td>40</td><td>102</td><td>39</td><td>36</td><td>46</td><td>20</td><td>39</td><td>1024</td><td>1234</td><td>1481</td></tr>
                <tr data-neck="41" data-raglan="38" data-sleeve="47" data-cuff="20" data-body="41"><td>42</td><td>107</td><td>41</td><td>38</td><td>47</td><td>20</td><td>41</td><td>1097</td><td>1326</td><td>1591</td></tr>
                <tr data-neck="42" data-raglan="41" data-sleeve="48" data-cuff="22" data-body="42"><td>44</td><td>112</td><td>42</td><td>41</td><td>48</td><td>22</td><td>42</td><td>1143</td><td>1372</td><td>1646</td></tr>
                <tr data-neck="43" data-raglan="43" data-sleeve="50" data-cuff="22" data-body="43"><td>46</td><td>117</td><td>43</td><td>43</td><td>50</td><td>22</td><td>43</td><td>1180</td><td>1417</td><td>1701</td></tr>
                <tr data-neck="44" data-raglan="46" data-sleeve="51" data-cuff="22" data-body="44"><td>48</td><td>122</td><td>44</td><td>46</td><td>51</td><td>22</td><td>44</td><td>1253</td><td>1509</td><td>1811</td></tr>
                <tr data-neck="46" data-raglan="48" data-sleeve="52" data-cuff="23" data-body="46"><td>50</td><td>127</td><td>46</td><td>48</td><td>52</td><td>23</td><td>46</td><td>1280</td><td>1554</td><td>1865</td></tr>
                <tr data-neck="47" data-raglan="51" data-sleeve="53" data-cuff="24" data-body="47"><td>52</td><td>132</td><td>47</td><td>51</td><td>53</td><td>24</td><td>47</td><td>1372</td><td>1646</td><td>1975</td></tr>
              </tbody>
            </table>
          </div>
          <div class="rc-tip" style="margin-top: 20px;">
            <strong>购线提示：</strong>总是多买一团线。保留收据，大多数毛线店接受退还未拆封的整团线。
          </div>
        </div>

        <div class="rc-card">
          <h2 data-icon="🧶">选线指南</h2>
          <div class="rc-instructions-box">
            <ul>
              <li><strong>天然纤维</strong>比合成纤维更耐用、保形性更好</li>
              <li><strong>羊毛</strong>对初学者更友好，容易拆改</li>
              <li><strong>羊驼毛</strong>较重，容易下垂 - 织样片时要仔细观察</li>
              <li><strong>"毛茸茸"的线</strong>会遮盖花样 - 织绞花用光滑的线</li>
              <li><strong>粗线</strong>对体型丰满者不友好 - 选择有垂感的线</li>
              <li><strong>可机洗线</strong>推荐用于儿童服装</li>
              <li><strong>细线</strong>织得慢 - 赶时间就用粗线</li>
            </ul>
          </div>
        </div>
      </div>

      <div id="variations" class="rc-tab-content">
        <div class="rc-card">
          <h2 data-icon="🎨">领型变化</h2>
          <h3>船领</h3>
          <p>量好想要的领围（确保能套过头）。用计算器算出针数，但一次性起所有针，直接圈织。不需要A记号。</p>
          <h3>V领</h3>
          <p>按圆领方式起针，但前片不是每隔一行加针，而是每4-6行在开头和结尾加针，直到所有前片针数加完。然后圈织。</p>
          <h3>领子选项</h3>
          <ul style="margin-left: 20px;">
            <li>立领</li><li>翻领</li><li>极简领边</li><li>钩针边</li>
          </ul>
        </div>

        <div class="rc-card">
          <h2 data-icon="🧥">开衫选项</h2>
          <h3>方法一：Steek剪裁</h3>
          <div class="rc-instructions-box">
            <ol>
              <li>在前中心多加6针</li>
              <li>这6针织种子针作为steek</li>
              <li>Steek一直织到下摆</li>
              <li>织完后用缝纫机在中心两侧缝一道</li>
              <li>在缝线中间剪开</li>
              <li>把steek折到内侧缝好</li>
              <li>加拉链或扣襟</li>
            </ol>
          </div>
          <h3>方法二：平织</h3>
          <p>领口完成后不圈织，继续来回织整件毛衣，前面留开口。加拉链或扣襟。</p>
        </div>

        <div class="rc-card">
          <h2 data-icon="🌈">颜色与花样</h2>
          <div class="rc-instructions-box">
            <ul>
              <li><strong>横条纹</strong>效果很好 - 插肩线自动对齐条纹</li>
              <li>用零线的好机会（确保密度相近）</li>
              <li>尝试绞花、凸纹花样或罗纹</li>
              <li>记录袖子花样以便两只袖子一致</li>
            </ul>
          </div>
          <div class="rc-tip">
            <strong>开心织吧！</strong>这是你的空白画布 - 随心创作！
          </div>
        </div>
      </div>
    </div>

    <footer class="rc-footer no-print">
      <p>基于 Jean Dickinson（Threads Magazine, 1988）和 Pamela Costello 的魔法插肩方法。</p>
      <p>本计算器仅供个人非商业使用。</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .raglan-calc {
    --rc-primary: #8B4513;
    --rc-primary-light: #D2691E;
    --rc-bg: #FFF8F0;
    --rc-card-bg: #FFFFFF;
    --rc-text: #333;
    --rc-border: #DDD;
    --rc-accent: #FF6B6B;
    color: var(--rc-text);
    line-height: 1.6;
  }

  :global(html.dark) .raglan-calc {
    --rc-primary: #D2961E;
    --rc-primary-light: #E8A83C;
    --rc-bg: #1a1a2e;
    --rc-card-bg: #222244;
    --rc-text: #e0e0e0;
    --rc-border: #444;
    --rc-accent: #FF8A8A;
  }

  .rc-header {
    text-align: center;
    padding: 40px 20px;
    background: linear-gradient(135deg, var(--rc-primary) 0%, var(--rc-primary-light) 100%);
    color: white;
    margin-bottom: 30px;
  }
  .rc-header h1 { font-size: 2.5rem; margin-bottom: 10px; }
  .rc-header p { font-size: 1.1rem; opacity: 0.9; }

  .rc-container { max-width: 1000px; margin: 0 auto; padding: 0 20px 20px; }

  .rc-card {
    background: var(--rc-card-bg);
    border-radius: 15px;
    padding: 25px;
    margin-bottom: 25px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }
  .rc-card h2 {
    color: var(--rc-primary);
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--rc-primary-light);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rc-card h2::before { content: attr(data-icon); font-size: 1.5rem; }
  .rc-card h3 { color: var(--rc-primary); margin: 20px 0 10px 0; }

  .rc-form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }
  .rc-form-group { display: flex; flex-direction: column; }
  .rc-form-group label { font-weight: 600; margin-bottom: 5px; color: var(--rc-primary); }
  .rc-form-group small { color: #888; font-size: 0.85rem; margin-bottom: 5px; }
  .rc-form-group input, .rc-form-group select {
    padding: 12px;
    border: 2px solid var(--rc-border);
    border-radius: 8px;
    font-size: 1rem;
    transition: border-color 0.3s;
    background: var(--rc-card-bg);
    color: var(--rc-text);
  }
  .rc-form-group input:focus { outline: none; border-color: var(--rc-primary); }

  .rc-result-box {
    background: linear-gradient(135deg, rgba(0,0,0,0.03) 0%, rgba(0,0,0,0.06) 100%);
    padding: 20px;
    border-radius: 10px;
    margin-top: 20px;
  }
  :global(html.dark) .rc-result-box {
    background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.06) 100%);
  }
  .rc-result-box h3 { margin-bottom: 15px; color: var(--rc-primary); }

  .rc-result-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
  }
  .rc-result-item {
    text-align: center;
    background: var(--rc-card-bg);
    padding: 15px;
    border-radius: 8px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
  }
  .rc-result-item .label { font-size: 0.9rem; color: #888; margin-bottom: 5px; }
  .rc-result-item .value { font-size: 1.8rem; font-weight: bold; color: var(--rc-primary); }
  .rc-result-item .unit { font-size: 0.9rem; color: #888; }

  .rc-cast-on-diagram {
    background: rgba(139,69,19,0.05);
    border: 2px dashed var(--rc-primary-light);
    border-radius: 10px;
    padding: 20px;
    margin-top: 20px;
  }
  .rc-cast-on-order {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    align-items: center;
    margin: 20px 0;
  }
  .rc-cast-on-item {
    background: var(--rc-card-bg);
    padding: 8px 15px;
    border-radius: 20px;
    font-size: 0.9rem;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  }
  .rc-cast-on-item.marker-a { background: var(--rc-accent); color: white; font-weight: bold; }
  .rc-cast-on-item.marker-b { background: #4ECDC4; color: white; font-weight: bold; }
  .rc-cast-on-item.stitches { background: var(--rc-primary); color: white; }
  .rc-arrow { color: #999; font-size: 1.2rem; }

  .rc-tip {
    background: #E8F5E9;
    border-left: 4px solid #4CAF50;
    padding: 15px;
    margin: 15px 0;
    border-radius: 0 8px 8px 0;
    color: #333;
  }
  :global(html.dark) .rc-tip { background: #1b3a1b; color: #c8e6c9; }

  .rc-warning {
    background: #FFF3E0;
    border-left: 4px solid #FF9800;
    padding: 15px;
    margin: 15px 0;
    border-radius: 0 8px 8px 0;
    color: #333;
  }
  :global(html.dark) .rc-warning { background: #3a2a10; color: #ffe0b2; }

  .rc-tabs { display: flex; gap: 5px; margin-bottom: 20px; flex-wrap: wrap; }
  .rc-tab {
    padding: 10px 20px;
    background: rgba(0,0,0,0.08);
    border: none;
    border-radius: 8px 8px 0 0;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.3s;
    color: var(--rc-text);
  }
  :global(html.dark) .rc-tab { background: rgba(255,255,255,0.1); }
  .rc-tab.active { background: var(--rc-primary); color: white; }
  .rc-tab-content { display: none; }
  .rc-tab-content.active { display: block; }

  .rc-yarn-table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 0.85rem; }
  .rc-yarn-table th, .rc-yarn-table td { padding: 10px 6px; text-align: center; border: 1px solid var(--rc-border); }
  .rc-yarn-table th { background: var(--rc-primary); color: white; font-size: 0.8rem; }
  .rc-yarn-table tbody tr:nth-child(even) { background: rgba(0,0,0,0.02); }
  :global(html.dark) .rc-yarn-table tbody tr:nth-child(even) { background: rgba(255,255,255,0.03); }
  .rc-yarn-table tbody tr:hover { background: rgba(139,69,19,0.08); cursor: pointer; }
  .rc-yarn-table tbody tr.selected { background: #FFE4B5 !important; font-weight: bold; }
  :global(html.dark) .rc-yarn-table tbody tr.selected { background: #5a4020 !important; }

  .rc-click-hint {
    text-align: center;
    color: var(--rc-primary);
    font-weight: bold;
    margin-bottom: 10px;
    padding: 10px;
    background: rgba(139,69,19,0.05);
    border-radius: 8px;
  }

  .rc-instructions-box {
    background: rgba(0,0,0,0.03);
    padding: 15px;
    border-radius: 8px;
    margin-top: 15px;
  }
  :global(html.dark) .rc-instructions-box { background: rgba(255,255,255,0.05); }
  .rc-instructions-box ul, .rc-instructions-box ol { margin-left: 20px; }
  .rc-instructions-box li { margin-bottom: 8px; }

  .rc-print-btn {
    background: var(--rc-primary);
    color: white;
    border: none;
    padding: 15px 30px;
    font-size: 1.1rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.3s, transform 0.2s;
    margin-top: 20px;
  }
  .rc-print-btn:hover { background: var(--rc-primary-light); transform: translateY(-2px); }

  .rc-footer { text-align: center; padding: 20px; color: #888; font-size: 0.9rem; }

  @media (max-width: 600px) {
    .rc-header h1 { font-size: 1.8rem; }
    .rc-form-grid { grid-template-columns: 1fr; }
    .rc-yarn-table { font-size: 0.75rem; }
    .rc-yarn-table th, .rc-yarn-table td { padding: 6px 3px; }
  }

  @media print {
    .no-print { display: none !important; }
    .rc-card { break-inside: avoid; box-shadow: none; border: 1px solid #ddd; }
    .rc-tabs { display: none; }
    #calculator, .rc-instructions-inline { display: block !important; }
  }
</style>

<script>
  // Tab switching
  document.querySelectorAll('.rc-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tabId = btn.getAttribute('data-tab');
      if (!tabId) return;
      document.querySelectorAll('.rc-tab-content').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.rc-tab').forEach(b => b.classList.remove('active'));
      document.getElementById(tabId)?.classList.add('active');
      btn.classList.add('active');
    });
  });

  // Size table row click
  document.querySelectorAll('.rc-yarn-table tbody tr').forEach(row => {
    row.addEventListener('click', () => {
      document.querySelectorAll('.rc-yarn-table tbody tr').forEach(r => r.classList.remove('selected'));
      (row as HTMLElement).classList.add('selected');

      const el = row as HTMLElement;
      (document.getElementById('neckCirc') as HTMLInputElement).value = el.dataset.neck || '';
      (document.getElementById('raglanLength') as HTMLInputElement).value = el.dataset.raglan || '';
      (document.getElementById('sleeveLength') as HTMLInputElement).value = el.dataset.sleeve || '';
      (document.getElementById('cuffCirc') as HTMLInputElement).value = el.dataset.cuff || '';
      (document.getElementById('bodyLength') as HTMLInputElement).value = el.dataset.body || '';

      calculateAll();

      // Switch to calculator tab
      document.querySelectorAll('.rc-tab-content').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.rc-tab').forEach(b => b.classList.remove('active'));
      document.getElementById('calculator')?.classList.add('active');
      document.querySelector('.rc-tab')?.classList.add('active');

      document.getElementById('neckCirc')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });

  // Input listeners
  document.querySelectorAll('#swatchWidth, #neckCirc, #raglanLength, #bodyLength, #cuffCirc, #sleeveLength').forEach(input => {
    input.addEventListener('input', calculateAll);
  });

  function calculateAll() {
    const swatchWidth = parseFloat((document.getElementById('swatchWidth') as HTMLInputElement).value) || 0;
    const neckCirc = parseFloat((document.getElementById('neckCirc') as HTMLInputElement).value) || 0;
    const cuffCirc = parseFloat((document.getElementById('cuffCirc') as HTMLInputElement).value) || 0;

    let gauge = 0;
    if (swatchWidth > 0) {
      gauge = 20 / swatchWidth;
      document.getElementById('gaugeResult')!.textContent = gauge.toFixed(2);
    } else {
      document.getElementById('gaugeResult')!.textContent = '--';
    }

    if (gauge > 0 && neckCirc > 0) {
      const totalNeck = Math.round(neckCirc * gauge);
      const backStitches = Math.round(totalNeck * 0.33);
      const sleeveStitches = Math.round(totalNeck * 0.25);
      const totalSleeveStitches = sleeveStitches * 2;
      const frontStitches = totalNeck - backStitches - totalSleeveStitches - 8;

      const leftFront = Math.round(frontStitches * 0.25);
      const rightFront = Math.round(frontStitches * 0.25);
      const centerFront = frontStitches - leftFront - rightFront;

      document.getElementById('totalNeck')!.textContent = String(totalNeck);
      document.getElementById('backStitches')!.textContent = String(backStitches);
      document.getElementById('sleeveStitches')!.textContent = String(sleeveStitches);
      document.getElementById('frontStitches')!.textContent = String(frontStitches);
      document.getElementById('leftFront')!.textContent = String(leftFront);
      document.getElementById('centerFront')!.textContent = String(centerFront);
      document.getElementById('rightFront')!.textContent = String(rightFront);

      const sleeve1CastOn = sleeveStitches + 2;
      const backCastOn = backStitches + 2;
      const sleeve2CastOn = sleeveStitches + 2;

      document.getElementById('sleeve1CastOn')!.textContent = sleeve1CastOn + '针';
      document.getElementById('backCastOn')!.textContent = backCastOn + '针';
      document.getElementById('sleeve2CastOn')!.textContent = sleeve2CastOn + '针';

      const initialCastOn = 1 + 1 + sleeve1CastOn + backCastOn + sleeve2CastOn + 1 + 1;
      document.getElementById('initialCastOn')!.textContent = String(initialCastOn);
    } else {
      document.getElementById('totalNeck')!.textContent = '--';
      document.getElementById('backStitches')!.textContent = '--';
      document.getElementById('sleeveStitches')!.textContent = '--';
      document.getElementById('frontStitches')!.textContent = '--';
      document.getElementById('leftFront')!.textContent = '--';
      document.getElementById('centerFront')!.textContent = '--';
      document.getElementById('rightFront')!.textContent = '--';
      document.getElementById('sleeve1CastOn')!.textContent = '袖+2';
      document.getElementById('backCastOn')!.textContent = '后片+2';
      document.getElementById('sleeve2CastOn')!.textContent = '袖+2';
      document.getElementById('initialCastOn')!.textContent = '--';
    }

    if (gauge > 0 && cuffCirc > 0) {
      document.getElementById('cuffStitches')!.textContent = String(Math.round(cuffCirc * gauge));
    } else {
      document.getElementById('cuffStitches')!.textContent = '--';
    }

    if (gauge > 0) {
      document.getElementById('underarmStitches')!.textContent = String(Math.round(gauge * 2.5));
    } else {
      document.getElementById('underarmStitches')!.textContent = '--';
    }
  }
</script>
